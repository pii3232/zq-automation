# CloudBase MySQL 数据库配置（部署时自动注入，本地开发需手动配置）
MYSQL_HOST=your-mysql-host.cloudbase.database.tencentcloudapi.com
MYSQL_PORT=3306
MYSQL_USER=your-username
MYSQL_PASSWORD=your-password
MYSQL_DATABASE=activation_system

# JWT 密钥（生产环境请修改）
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production

# 服务器配置（CloudBase 会自动注入 PORT）
SERVER_PORT=5000
SERVER_HOST=0.0.0.0

# 邮件配置
MAIL_SERVER=smtp.qq.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@qq.com
MAIL_PASSWORD=your-email-auth-code
MAIL_DEFAULT_SENDER=noreply@activation.com

# 开发环境配置
FLASK_ENV=production
SQLALCHEMY_ECHO=False
